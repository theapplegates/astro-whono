---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { getThemeSettings } from '../../lib/theme-settings';
import { createWithBase } from '../../utils/format';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { settings } = getThemeSettings();
const socialLinks = settings.site.socialLinks;

type SocialActionItem = {
  key: string;
  href: string;
  label: string;
  icon: 'github' | 'x-twitter' | 'mail' | 'rss';
};

type ContactItem = {
  key: string;
  href: string;
  label: string;
  icon: 'github' | 'x-twitter' | 'mail';
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const socialItems: SocialActionItem[] = [
  socialLinks.github
    ? { key: 'github', href: socialLinks.github, label: 'GitHub', icon: 'github' as const }
    : null,
  socialLinks.x
    ? { key: 'x', href: socialLinks.x, label: 'X', icon: 'x-twitter' as const }
    : null,
  socialLinks.email
    ? { key: 'email', href: `mailto:${socialLinks.email}`, label: 'Email', icon: 'mail' as const }
    : null,
  socialLinks.rss
    ? { key: 'rss', href: withBase('/rss.xml'), label: 'RSS', icon: 'rss' as const }
    : null
].filter((item): item is SocialActionItem => item !== null);

const contactItems: ContactItem[] = [
  socialLinks.email
    ? { key: 'email', href: `mailto:${socialLinks.email}`, label: 'Email', icon: 'mail' as const, text: socialLinks.email }
    : null,
  socialLinks.github
    ? {
        key: 'github',
        href: socialLinks.github,
        label: 'GitHub',
        icon: 'github' as const,
        text: formatExternalLabel(socialLinks.github)
      }
    : null,
  socialLinks.x
    ? {
        key: 'x',
        href: socialLinks.x,
        label: 'X',
        icon: 'x-twitter' as const,
        text: formatExternalLabel(socialLinks.x)
      }
    : null
].filter((item): item is ContactItem => item !== null);
---

<BaseLayout title="关于" bodyClass="about-page">
  <div class="page-header page-header--about">
    <h1 class="page-title">关于</h1>
    {
      socialItems.length ? (
        <div class="page-actions">
          {socialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.label} title={item.label}>
              <Icon name={item.icon} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>
  <p class="about-intro-line">
    Whono是一个基于 Astro 的极简双栏写作主题：干净、快速、为阅读而设计。<br />
    内容以 Markdown 写作，支持暗色模式、代码高亮、RSS 与沉浸式阅读，适合作为个人写作与轻量内容发布的起点。<br />
    主题已开源维护，如果你有改进建议或想一起完善，欢迎创建 <a href="https://github.com/cxro/astro-whono/issues">Issue</a> 交流。
  </p>
  <h2 class="section-title about-section-title">栏目指引</h2>
  <div class="site-guide">
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">随笔</h3>
        <span class="site-guide-link">/essay/</span>
      </div>
      <p class="site-guide-desc">文章流列表（含未归档内容）。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">絮语</h3>
        <span class="site-guide-link">/bits/</span>
      </div>
      <p class="site-guide-desc">短内容动态流，碎片想法（支持多图）。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">小记</h3>
        <span class="site-guide-link">/memo/</span>
      </div>
      <p class="site-guide-desc">整理一些值得留存的片刻与回忆。</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">归档</h3>
        <span class="site-guide-link">/archive/</span>
      </div>
      <p class="site-guide-desc">按年份分组的归档目录。</p>
    </article>
  </div>

  <h2 class="section-title about-section-title">技术栈</h2>
  <div class="tech-stack">
    <section class="tech-group">
      <div class="tech-group-title">构建与渲染</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Astro / Vite</span>
          </div>
          <div class="tech-item-desc">内容站点与构建</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">CSS / 排版</span>
          </div>
          <div class="tech-item-desc">排版与阅读体验</div>
        </li>
      </ul>
    </section>
    <section class="tech-group">
      <div class="tech-group-title">语言与工具</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">TypeScript</span>
          </div>
          <div class="tech-item-desc">类型约束与脚本支持</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Markdown</span>
          </div>
          <div class="tech-item-desc">内容写作与发布流程</div>
        </li>
      </ul>
    </section>
    
  </div>

  <h2 class="section-title about-section-title">常见问题</h2>
  <section class="qa-list" aria-label="常见问题">
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么我部署后会看到 SITE_URL is not set 警告？</summary>
      <p class="qa-answer">因为没配置生产域名。未设置时会用占位域名，<code>canonical</code>/<code>og:url</code>/<code>sitemap</code>/<code>robots</code> 会不完整。部署平台里环境变量中添加 <code>SITE_URL=https://你的域名</code>，重新构建即可。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么有的文章没出现在归档里？</summary>
      <p class="qa-answer">归档会过滤掉 <code>archive: false</code> 的文章。它们仍然是“已发布可访问”的，但不会出现在归档列表与归档 RSS 中（用于少数不想被目录收录的内容）。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>为什么我在 /essay/ 点开文章会跳到 /archive/.../？</summary>
      <p class="qa-answer">项目把文章详情统一在 <code>/archive/{'{'}slug{'}'}/</code>，<code>/essay/</code> 主要作为文章流列表入口，这样可以避免重复详情路由，便于长期维护。</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>如何反馈问题或参与改进？</summary>
      <p class="qa-answer">直接在仓库创建 <a href="https://github.com/cxro/astro-whono/issues">Issue</a>，或提交 <a href="https://github.com/cxro/astro-whono/pulls">Pull Request</a>。</p>
    </details>
  </section>

  {
    contactItems.length ? (
      <>
        <h2 class="section-title about-section-title">联系</h2>
        <section class="contact-block" aria-label="联系方式">
          <p class="contact-note">如果你有问题、建议，可以通过以下方式联系</p>
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head">
                  <Icon name={item.icon} class="contact-icon" />
                  <span>{item.label}：</span>
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : null
  }

</BaseLayout>
